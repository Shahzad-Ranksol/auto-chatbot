PORT=3000
NODE_ENV=production

# Set this to your public domain when deploying (e.g. https://myapp.onrender.com)
# Leave blank to auto-detect from the request host
BASE_URL=

# ── Database ───────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=autochatbot

# ── Security ───────────────────────────────────────────────────────────────────
# Generate a strong random string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string

# ── AI Provider Keys (optional — server-wide fallback for all chatbots) ────────
# Users can also supply their own keys via Settings > AI Configuration.
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...
